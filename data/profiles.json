    "layer3": true,
    "l3_sections": {
      "loopback": {
        "enabled": true,
        "ip": "",
        "mask": "255.255.255.255",
        "description": "Switch MGMT / Router-ID"
      },
      "routed_mgmt": {
        "enabled": false,
        "interface": "",
        "ip": "",
        "mask": "255.255.255.252",
        "description": "Routed Uplink"
      },
