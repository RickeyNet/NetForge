      },
      {
        "vlan": "3",
        "description": "User_Gateway",
        "ip": "",
        "mask": "",
        "helper_addresses": []
      }
    ],
    "ospf": {
      "enabled": false,
      "process_id": "1",
      "passive_default": false,
      "passive_interfaces": [],
      "networks": []
    },
    "bgp": {
      "enabled": true,
      "local_asn": "65000",
      "peer_asn": "65001",
      "peers": []
    },
    "acls": [
      {
        "name": "blocked_addresses",
        "type": "extended",
        "rules": [
          {
            "action": "remark",
            "text": "*** Allow mgmt networks ***"
          },
          {
            "action": "permit",
            "protocol": "ip",
            "source": "x.x.x.x",
            "source_wildcard": "0.0.0.0",
            "dest": "any",
            "log": false
          },
          {
            "action": "remark",
            "text": "*** Allow trusted networks ***"
          },
          {
            "action": "permit",
            "protocol": "ip",
            "source": "x.x.x.x",
            "source_wildcard": "0.0.0.0",
            "dest": "any",
            "log": false
          },
          {
            "action": "remark",
            "text": "*** Denied ***"
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "0.0.0.0",
            "source_wildcard": "255.0.0.0",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "10.0.0.0",
            "source_wildcard": "0.255.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "127.0.0.0",
            "source_wildcard": "0.255.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "169.254.0.0",
            "source_wildcard": "0.0.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "172.16.0.0",
            "source_wildcard": "0.15.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "192.168.0.0",
            "source_wildcard": "0.0.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "224.0.0.0",
            "source_wildcard": "15.255.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "240.0.0.0",
            "source_wildcard": "15.255.255.255",
            "dest": "any",
            "log": true
          },
          {
            "action": "permit",
            "protocol": "ip",
            "source": "any",
            "dest": "any",
            "log": false
          }
        ]
      },
      {
        "name": "deny_access_to_mgmt",
        "type": "extended",
        "rules": [
          {
            "action": "remark",
            "text": "*** Block user nets from reaching mgmt ***"
          },
          {
            "action": "deny",
            "protocol": "ip",
            "source": "x.x.x.x",
            "source_wildcard": "0.0.0.0",
            "dest": "x.x.x.x",
            "dest_wildcard": "0.0.0.0",
            "log": true
          },
          {
            "action": "permit",
            "protocol": "ip",
            "source": "any",
            "dest": "any",
            "log": false
          }
        ]
      }
    ]
  }
}