  "BGP Edge": {
    "domain_name": "",
    "mgmt_vlan": "",
    "vlan_definitions": "vlan 2\n name 3\nexit\n\nvlan 4\n name User\nexit",
    "role_variables": {},
    "port_assignments": [],
    "layer3": true,
    "mgmt_style": "loopback",
    "svis": [
      {
        "vlan": "2",
        "description": "Uplink_to_ISP",
        "ip": "",
        "mask": "",
